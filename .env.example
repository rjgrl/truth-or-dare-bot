# Supabase PostgreSQL connection string (Project Settings → Database → Connection string → URI)
# Use the "Transaction" pooler URI for server apps, or direct connection for local dev
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Discord bot token — https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Application (client) ID from Discord Developer Portal
CLIENT_ID=your_application_id_here

# Comma-separated user IDs that can use /admin commands (in addition to Manage Server)
ADMIN_USER_IDS=

# Cooldown between question commands per user (seconds)
COOLDOWN_SECONDS=8

# How many recent questions to avoid repeating per guild
RECENT_QUESTION_POOL=50

# Dare completion timer default (seconds), 0 = disabled
DARE_TIMER_SECONDS=60

# Enable NSFW-rated questions in channels marked NSFW (still respects per-channel toggle)
ALLOW_NSFW_DEFAULT=false

# Optional AI fallback when no questions match (requires your own API key) — disabled by default
ENABLE_AI_FALLBACK=false
OPENAI_API_KEY=

# Embed color (hex without #)
EMBED_COLOR=5865F2

# Optional: Max players per party (server admins can override with /party setmax, hard cap 50)
PARTY_MAX_PLAYERS=25

# HTTP port for keep-alive pings (Render/Railway set PORT automatically)
PORT=3000
